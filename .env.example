# ─── Application ───────────────────────────────────────────────
APP_NAME=InternRoute
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ─── Frontend ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ─── LLM (Gemini) ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Vector Database (ChromaDB) ──────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_CV=internroute_cv
CHROMA_COLLECTION_INTERVIEWS=internroute_interviews

# ─── File Storage ────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ─── Security (production için güncellenecek) ────────────────────
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Email verification ────────────────────────────────────────
# Default (bootcamp): leave empty → 6-digit code shows on the signup screen.
#
# Optional real email — Resend free (simpler than Brevo SMTP):
# 1) https://resend.com → create API key
# 2) Without your own domain you can only email YOUR Resend signup address
#    using from onboarding@resend.dev
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=InternRoute <onboarding@resend.dev>
#
# SMTP/Brevo is optional and often blocked for new free accounts — not required.
VERIFICATION_CODE_TTL_MINUTES=10

# ─── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
